# AnySearch API Key (optional - anonymous access works with lower limits)
ANYSEARCH_API_KEY=

# AnySearch tool discovery cache TTL in milliseconds (default 3600000 = 1 hour)
# Set to 0 to always re-discover on first call after expiry.
# Set to a small value (e.g. 60000) in development for faster iteration.
# ANYSEARCH_CACHE_TTL_MS=3600000

# LLM API Configuration (OpenAI-compatible format)
LLM_API_KEY=
LLM_BASE_URL=https://api.longcat.chat/openai/v1
LLM_MODEL=LongCat-2.0

# Max tokens (optional, default 4096)
# LLM_MAX_TOKENS=8192
