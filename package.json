{
  "name": "mini-agent-mcp",
  "version": "1.0.9",
  "description": "MCP server with an integrated ReAct mini-agent that autonomously uses tools. Includes AnySearch integration for web search and multi-model LLM communication via MCP sampling.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mini-agent-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "assets",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "node dist/index.js --test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agent",
    "reasoning-agent",
    "llm",
    "ai-agent",
    "search",
    "anysearch",
    "multi-model",
    "sampling"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Microbiosis/mini-agent-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Microbiosis/mini-agent-mcp/issues"
  },
  "homepage": "https://github.com/Microbiosis/mini-agent-mcp#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "sharp": "^0.35.3",
    "typescript": "^5.7.0"
  }
}
