{
  "name": "mini-agent-mcp",
  "version": "1.1.0",
  "description": "MCP server with an integrated ReAct mini-agent that autonomously uses tools. Includes AnySearch integration for web search and multi-model LLM communication via MCP sampling.",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agent": {
      "types": "./dist/agent/react.d.ts",
      "import": "./dist/agent/react.js"
    },
    "./agent/llm": {
      "types": "./dist/agent/llm.d.ts",
      "import": "./dist/agent/llm.js"
    },
    "./tools/manager": {
      "types": "./dist/tools/manager.d.ts",
      "import": "./dist/tools/manager.js"
    },
    "./tools/internal-modules": {
      "types": "./dist/tools/internal-modules.d.ts",
      "import": "./dist/tools/internal-modules.js"
    },
    "./workflow": {
      "types": "./dist/workflow/index.d.ts",
      "import": "./dist/workflow/index.js"
    },
    "./memory": {
      "types": "./dist/memory/index.d.ts",
      "import": "./dist/memory/index.js"
    },
    "./skill": {
      "types": "./dist/skill/index.d.ts",
      "import": "./dist/skill/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "mini-agent-mcp": "dist/index.js"
  },
  "mcpName": "io.github.Microbiosis/mini-agent-mcp",
  "files": [
    "dist",
    "assets",
    "README.md",
    "server.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "npm run test:meta && npm run test:dag && npm run test:research && npm run test:random && npm run test:dag-validation && npm run test:toolmanager && npm run test:internal-modules && npm run test:rule-mode && npm run test:sampling && npm run test:secret && npm run test:exports && npm run test:smoke",
    "test:meta": "node scripts/test-package-metadata.mjs",
    "test:dag": "node scripts/test-dag-buildStepTask.mjs",
    "test:research": "node scripts/test-research-parser.mjs",
    "test:random": "node scripts/test-random-validation.mjs",
    "test:dag-validation": "node scripts/test-dag-validation.mjs",
    "test:toolmanager": "node scripts/test-toolmanager.mjs",
    "test:internal-modules": "node scripts/test-internal-modules.mjs",
    "test:rule-mode": "node scripts/test-rule-mode.mjs",
    "test:sampling": "node scripts/test-llm-sampling-context.mjs",
    "test:secret": "node scripts/test-secret-scan.mjs",
    "test:exports": "node scripts/test-package-exports.mjs",
    "test:smoke": "node dist/index.js --test",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agent",
    "reasoning-agent",
    "llm",
    "ai-agent",
    "search",
    "anysearch",
    "multi-model",
    "sampling"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Microbiosis/mini-agent-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Microbiosis/mini-agent-mcp/issues"
  },
  "homepage": "https://github.com/Microbiosis/mini-agent-mcp#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fastmcp": "^4.4.0",
    "openai": "^6.46.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.64.0"
  }
}
