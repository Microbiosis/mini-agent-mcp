{
  "name": "mini-agent-mcp",
  "version": "1.0.32",
  "description": "MCP server with an integrated ReAct mini-agent that autonomously uses tools. Includes AnySearch integration for web search and multi-model LLM communication via MCP sampling.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mini-agent-mcp": "dist/index.js"
  },
  "mcpName": "io.github.Microbiosis/mini-agent-mcp",
  "files": [
    "dist",
    "assets",
    "README.md",
    "server.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "node dist/index.js --test",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agent",
    "reasoning-agent",
    "llm",
    "ai-agent",
    "search",
    "anysearch",
    "multi-model",
    "sampling"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Microbiosis/mini-agent-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Microbiosis/mini-agent-mcp/issues"
  },
  "homepage": "https://github.com/Microbiosis/mini-agent-mcp#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fastmcp": "^4.4.0",
    "openai": "^6.46.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.64.0"
  }
}
